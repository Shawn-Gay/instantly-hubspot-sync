# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Instantly ───────────────────────────────────────────
INSTANTLY_API_KEY=your_instantly_api_key
WEBHOOK_BASE_URL=https://your-app.up.railway.app

# ─── Zoho CRM ────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Long-lived refresh token — generate once via Zoho API Console (self-client)
ZOHO_REFRESH_TOKEN=
# Region-specific — change if your Zoho account is in EU/AU/IN/etc.
ZOHO_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_API_BASE_URL=https://www.zohoapis.com/crm/v2
# API field name for the email sent counter (Zoho CRM > Settings > Fields > Leads module)
ZOHO_EMAILS_SENT_FIELD=Emails_Sent

# ─── JustCall ────────────────────────────────────────────
# Must match the exact disposition string JustCall sends
JUSTCALL_MEETING_BOOKED_OUTCOME=Meeting Booked

# ─── Server (optional) ───────────────────────────────────
PORT=3000
WEBHOOK_SECRET=
AUTO_REGISTER_WEBHOOKS=true
